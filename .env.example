# DevTrace Configuration

# Chrome DevTools Protocol port (default: 9222)
DEVTRACE_PORT=9222

# Local API port (default: 3333)
DEVTRACE_API_PORT=3333

# Maximum number of sessions to keep (default: 50)
DEVTRACE_MAX_SESSIONS=50

# Chrome binary path (auto-detected if not set)
# DEVTRACE_CHROME_PATH=/Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome

# Chrome user profile path (uses temp profile if not set)
# DEVTRACE_CHROME_PROFILE=~/Library/Application\ Support/Google/Chrome/Default

# Enable verbose logging (default: false)
# DEVTRACE_DEBUG=false
